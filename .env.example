# APP_URL: The public URL where StarTurn is hosted.
# Required in production for magic link emails to work.
APP_URL=""

# RESEND_API_KEY: Required for sending magic link emails via Resend.
# Get your API key from https://resend.com
# If not set, magic links will be logged to the server console (dev mode).
RESEND_API_KEY=""

# RESEND_FROM: The "from" address for magic link emails.
# Must be a verified domain in your Resend account.
# Default: StarTurn <noreply@starturn.app>
RESEND_FROM="StarTurn <noreply@yourdomain.com>"

# DATA_DIR: Directory for the SQLite database file.
# Default: ./data
# DATA_DIR="./data"

# PORT: Server port.
# Default: 3000
# PORT=3000
